{
  "meta": {
    "is_partial": true,
    "description": "환경설정 보안 탭 콘텐츠"
  },
  "id": "tab_content_security",
  "type": "basic",
  "name": "Div",
  "if": "{{(_global.activeSettingsTab || query.tab) === 'security'}}",
  "children": [
    {
      "id": "card_security_settings",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "card-stack-item"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:admin.settings.security.title"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:admin.settings.security.desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "row-stack"
          },
          "children": [
            {
              "id": "toggle_force_https",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-between"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-heading"
                          },
                          "text": "$t:admin.settings.security.force_https"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-1"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "$t:admin.settings.security.force_https_desc"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['security.force_https']}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.['security.force_https']?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "name": "security.force_https",
                    "size": "md",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "id": "toggle_allow_internal_outbound_urls",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-between"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-heading"
                          },
                          "text": "$t:admin.settings.security.allow_internal_outbound_urls"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "$t:admin.settings.security.allow_internal_outbound_urls_desc"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['security.allow_internal_outbound_urls']}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.['security.allow_internal_outbound_urls']?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "name": "security.allow_internal_outbound_urls",
                    "size": "md",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "id": "toggle_login_attempt",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-between"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-center"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-heading"
                          },
                          "text": "$t:admin.settings.security.login_attempt_limit"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-1"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "$t:admin.settings.security.login_attempt_limit_desc"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.errors?.['security.login_attempt_enabled']}}",
                      "props": {
                        "className": "form-error"
                      },
                      "text": "{{_local.errors?.['security.login_attempt_enabled']?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "Toggle",
                  "props": {
                    "name": "security.login_attempt_enabled",
                    "size": "md",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "id": "field_auth_token_lifetime",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.security.auth_token_lifetime"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "security.auth_token_lifetime",
                    "placeholder": "30",
                    "min": 0,
                    "max": 3600,
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "input input-w-md {{_local.errors?.['security.auth_token_lifetime'] ? 'input-error' : ''}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['security.auth_token_lifetime']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['security.auth_token_lifetime']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-hint mt-1"
                  },
                  "text": "$t:admin.settings.security.zero_means_unlimited"
                }
              ]
            },
            {
              "id": "field_max_login_attempts",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.security.max_login_attempts"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "security.max_login_attempts",
                    "placeholder": "5",
                    "min": 0,
                    "max": 100,
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "input input-w-md {{_local.errors?.['security.max_login_attempts'] ? 'input-error' : ''}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['security.max_login_attempts']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['security.max_login_attempts']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-hint mt-1"
                  },
                  "text": "$t:admin.settings.security.zero_means_unlimited"
                }
              ]
            },
            {
              "id": "field_login_lockout_time",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": ""
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:admin.settings.security.login_lockout_time_full"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "security.login_lockout_time",
                    "placeholder": "5",
                    "min": 0,
                    "max": 1440,
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "input input-w-md {{_local.errors?.['security.login_lockout_time'] ? 'input-error' : ''}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['security.login_lockout_time']}}",
                  "props": {
                    "className": "form-error"
                  },
                  "text": "{{_local.errors?.['security.login_lockout_time']?.[0] ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-hint mt-1"
                  },
                  "text": "$t:admin.settings.security.zero_means_unlimited"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "card_app_key",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "card-stack-item"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "card-title"
          },
          "text": "$t:admin.settings.security.app_key"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-description"
          },
          "text": "$t:admin.settings.security.app_key_desc"
        },
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "form-label"
              },
              "text": "$t:admin.settings.security.current_app_key"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-center gap-3"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "row-stack"
                  }
                }
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "value": "{{appKey?.data?.app_key ?? ''}}",
                    "disabled": true,
                    "className": "input flex-1 font-mono"
                  }
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "disabled": "{{_computed.isReadOnly}}",
                    "className": "px-4 py-2 bg-white dark:bg-gray-700 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 font-medium transition-colors whitespace-nowrap"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "w-full px-4 py-2 bg-white dark:bg-gray-700 text-body border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 font-medium transition-colors"
                      }
                    }
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "openModal",
                      "target": "settings_password_confirm_modal"
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:admin.settings.security.regenerate_key"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-tertiary"
              },
              "text": "$t:admin.settings.security.app_key_warning"
            }
          ]
        }
      ]
    }
  ],
  "props": {
    "className": "card-stack"
  }
}
