{
  "version": "1.0.0",
  "layout_name": "mypage/addresses",
  "extends": "_user_base",
  "permissions": [],
  "initLocal": {},
  "transition_overlay": {
    "enabled": true,
    "style": "spinner",
    "target": "mypage_tab_content",
    "fallback_target": "main_content_area",
    "spinner": {
      "component": "PageLoading"
    }
  },
  "computed": {
    "currentTab": "addresses"
  },
  "data_sources": [
    {
      "id": "addresses",
      "label_key": "$t:editor.data_source.addresses",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/user/addresses",
      "method": "GET",
      "auto_fetch": true,
      "auth_mode": "required",
      "loading_strategy": "progressive"
    }
  ],
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-gray-50 dark:bg-gray-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "comment": "페이지 제목",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "user",
                      "size": "xl",
                      "className": "text-gray-900 dark:text-white"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-gray-900 dark:text-white"
                    },
                    "text": "$t:mypage.title"
                  }
                ]
              },
              {
                "comment": "탭 네비게이션",
                "partial": "partials/mypage/_tab_navigation.json"
              },
              {
                "comment": "탭 컨텐츠 영역 (스켈레톤 타겟)",
                "type": "basic",
                "name": "Div",
                "id": "mypage_tab_content",
                "children": [
                  {
                    "comment": "배송지 관리",
                    "partial": "partials/mypage/addresses/_list.json"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": [
    {
      "partial": "partials/mypage/addresses/_modal_address.json"
    },
    {
      "partial": "partials/mypage/addresses/_modal_confirm_overwrite.json"
    },
    {
      "partial": "partials/mypage/addresses/_modal_confirm_delete.json"
    }
  ]
}