{
  "meta": {
    "is_partial": true,
    "description": "쇼핑몰 홍보 카드"
  },
  "type": "basic",
  "name": "Button",
  "props": {
    "className": "block w-full text-left bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl p-5 text-white hover:shadow-lg transition-shadow cursor-pointer"
  },
  "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "{{_global.shopBase}}/products" } }],
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": { "className": "flex items-center gap-2 mb-2" },
      "children": [
        { "type": "basic", "name": "Icon", "props": { "name": "shopping-cart", "className": "w-5 h-5" } },
        { "type": "basic", "name": "Span", "props": { "className": "font-semibold" }, "text": "$t:home.shop" }
      ]
    },
    { "type": "basic", "name": "P", "props": { "className": "text-sm opacity-90" }, "text": "$t:home.shop_description" }
  ]
}
