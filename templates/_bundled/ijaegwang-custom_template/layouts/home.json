{
    "version": "1.0.0",
    "layout_name": "home",
    "permissions": [],
    "extends": "_user_base",
    "meta": {
        "title": "$t:user.home.page_title",
        "description": "$t:user.home.page_description"
    },
    "data_sources": [
        {
            "id": "memos",
            "type": "api",
            "endpoint": "/api/modules/gnuboard7-hello_module/memos",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "params": {
                "per_page": 10
            },
            "fallback": {
                "data": {
                    "data": []
                }
            }
        }
    ],
    "slots": {
        "content": [
            {
                "comment": "=== 환영 카드 ===",
                "id": "welcome_card",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "rounded-lg border border-gray-200 bg-blue-50 px-6 py-6 mb-6"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                            "className": "text-2xl font-bold text-gray-900 mb-2"
                        },
                        "text": "$t:user.home.welcome_title"
                    },
                    {
                        "type": "basic",
                        "name": "Span",
                        "props": {
                            "className": "text-base text-gray-700"
                        },
                        "text": "$t:user.home.welcome_description"
                    }
                ]
            },
            {
                "comment": "=== Memo 목록 섹션 ===",
                "id": "memo_section",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "mb-6"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "H2",
                        "props": {
                            "className": "text-xl font-semibold text-gray-900 mb-3"
                        },
                        "text": "$t:user.home.memos_title"
                    },
                    {
                        "comment": "Memo 비어있음 안내",
                        "type": "basic",
                        "name": "Div",
                        "if": "{{(memos?.data?.data ?? []).length === 0}}",
                        "props": {
                            "className": "rounded border border-gray-200 bg-gray-50 px-4 py-6 text-center text-gray-500"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Span",
                                "text": "$t:user.home.memos_empty"
                            }
                        ]
                    },
                    {
                        "comment": "Memo 목록 iteration",
                        "type": "basic",
                        "name": "Div",
                        "if": "{{(memos?.data?.data ?? []).length > 0}}",
                        "props": {
                            "className": "space-y-3"
                        },
                        "children": [
                            {
                                "type": "basic",
                                "name": "Div",
                                "iteration": {
                                    "source": "{{memos?.data?.data ?? []}}",
                                    "item_var": "memo"
                                },
                                "props": {
                                    "className": "rounded border border-gray-200 bg-white px-4 py-3 hover:border-blue-400"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "H3",
                                        "props": {
                                            "className": "text-base font-semibold text-gray-900 mb-1"
                                        },
                                        "text": "{{memo.title ?? ''}}"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Span",
                                        "props": {
                                            "className": "text-sm text-gray-600"
                                        },
                                        "text": "{{memo.content ?? ''}}"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "comment": "=== 홈 복귀 버튼 (액션 시연) ===",
                "id": "home_action",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "flex justify-center"
                },
                "children": [
                    {
                        "type": "basic",
                        "name": "Button",
                        "props": {
                            "className": "px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 cursor-pointer",
                            "data-testid": "home-button"
                        },
                        "actions": [
                            {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                    "path": "/"
                                }
                            }
                        ],
                        "text": "$t:user.home.back_to_home"
                    }
                ]
            }
        ]
    }
}
