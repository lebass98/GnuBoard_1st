    {
      "label": "$t:layout_editor.palette.group.design",
      "kind": "design",
      "components": [
        "Div",
        "Container",
        "Flex",
        "Grid",
        "SectionLayout",
        "ThreeColumnLayout",
        "Span",
        "P",
        "H1",
        "H2",
