{
  "version": "1.0.0",
  "layout_name": "admin_page_list",
  "permissions": [
    "sirsoft-page.pages.read"
  ],
  "extends": "_admin_base",
  "meta": {
    "title": "$t:sirsoft-page.admin.page.page_title",
    "description": "$t:sirsoft-page.admin.page.page_description"
  },
  "state": {
    "searchField": "all",
    "searchQuery": ""
  },
  "transition_overlay": {
    "wait_for": [
      "pages"
    ]
  },
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "global",
        "selectedIds_admin_pages": [],
        "isBulkPublishing": false,
        "_local": {
          "searchField": "{{query['filters[0][field]'] || 'all'}}",
          "searchQuery": "{{query['filters[0][value]'] || ''}}"
        }
      }
    }
  ],
  "data_sources": [
    {
      "id": "pages",
      "label_key": "$t:sirsoft-page.editor.data_source.pages",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-page/admin/pages",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "errorHandling": {
        "403": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      },
      "params": {
        "page": "{{query.page}}",
        "per_page": "{{query.per_page}}",
        "published": "{{query.published}}",
        "filters[0][field]": "{{query['filters[0][field]'] || 'all'}}",
        "filters[0][value]": "{{query['filters[0][value]']}}",
        "filters[0][operator]": "{{query['filters[0][operator]']}}",
        "sort_by": "{{query.sort_by}}",
        "sort_order": "{{query.sort_order}}"
      },
      "fallback": {
        "data": {
          "data": [],
          "meta": {
            "current_page": 1,
            "last_page": 1,
            "per_page": 20,
            "total": 0
          }
        }
      }
    }
  ],
  "slots": {
    "content": [
      {
        "id": "page_list_content",
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "admin-page-content-fluid"
        },
        "responsive": {
          "portable": {
            "props": {
              "className": "admin-page-content-fluid-compact"
            }
          }
        },
        "children": [
          {
            "id": "page_header",
            "type": "composite",
            "name": "PageHeader",
            "props": {
              "title": "$t:sirsoft-page.admin.page.title",
              "description": "$t:sirsoft-page.admin.page.description"
            },
            "children": [
              {
                "id": "refresh_button",
                "type": "basic",
                "name": "Button",
                "props": {
                  "className": "btn-icon"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/admin/pages",
                      "mergeQuery": false
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "refresh",
                      "size": "sm"
                    }
                  }
                ]
              },
              {
                "id": "add_page_button",
                "type": "basic",
                "name": "Button",
                "props": {
                  "className": "btn btn-primary",
                  "disabled": "{{pages?.data?.abilities?.can_create !== true}}"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/admin/pages/create"
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "plus",
                      "size": "sm"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:sirsoft-page.admin.page.add_page"
                  }
                ]
              }
            ]
          },
          {
            "id": "search_filter_area",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "admin-card"
            },
            "children": [
              {
                "id": "search_row",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex-center flex-row gap-3"
                },
                "children": [
                  {
                    "id": "search_field_select",
                    "type": "composite",
                    "name": "Select",
                    "props": {
                      "value": "{{_local.searchField || 'all'}}",
                      "className": "select-composite w-28",
                      "options": [
                        {
                          "label": "$t:sirsoft-page.admin.page.search_fields.all",
                          "value": "all"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.search_fields.title",
                          "value": "title"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.search_fields.slug",
                          "value": "slug"
                        }
                      ]
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "setState",
                        "params": {
                          "searchField": "{{$event.target.value}}"
                        }
                      }
                    ]
                  },
                  {
                    "id": "search_input",
                    "type": "basic",
                    "name": "Input",
                    "props": {
                      "type": "text",
                      "placeholder": "$t:sirsoft-page.admin.page.search_placeholder",
                      "value": "{{_local.searchQuery || ''}}",
                      "className": "flex-1 min-w-0"
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "setState",
                        "params": {
                          "searchQuery": "{{$event.target.value}}"
                        }
                      },
                      {
                        "type": "keypress",
                        "key": "Enter",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/pages",
                          "mergeQuery": true,
                          "query": {
                            "filters[0][field]": "{{_local.searchField || 'all'}}",
                            "filters[0][value]": "{{$event.target.value}}",
                            "filters[0][operator]": "like",
                            "page": 1
                          },
                          "transition_overlay_target": "pages_data_grid__body"
                        }
                      }
                    ]
                  },
                  {
                    "id": "search_button",
                    "type": "basic",
                    "name": "Button",
                    "props": {
                      "className": "btn btn-primary"
                    },
                    "actions": [
                      {
                        "type": "click",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/pages",
                          "mergeQuery": true,
                          "query": {
                            "filters[0][field]": "{{_local.searchField || 'all'}}",
                            "filters[0][value]": "{{_local.searchQuery || ''}}",
                            "filters[0][operator]": "like",
                            "page": 1
                          },
                          "transition_overlay_target": "pages_data_grid__body"
                        }
                      }
                    ],
                    "children": [
                      {
                        "type": "basic",
                        "name": "Span",
                        "text": "$t:sirsoft-page.admin.page.search"
                      }
                    ]
                  }
                ],
                "responsive": {
                  "portable": {
                    "props": {
                      "className": "row-stack"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "children": [
                          {
                            "id": "mobile_search_row",
                            "type": "basic",
                            "name": "Div",
                            "props": {
                              "className": "flex flex-row gap-2 items-center"
                            },
                            "children": [
                              {
                                "id": "mobile_search_field_select",
                                "type": "composite",
                                "name": "Select",
                                "props": {
                                  "value": "{{_local.searchField || 'all'}}",
                                  "className": "w-24 px-3 py-2 bg-gray-100 dark:bg-gray-700 border-0 rounded-lg text-gray-700 dark:text-gray-200 text-sm font-medium focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400",
                                  "options": [
                                    {
                                      "label": "$t:sirsoft-page.admin.page.search_fields.all",
                                      "value": "all"
                                    },
                                    {
                                      "label": "$t:sirsoft-page.admin.page.search_fields.title",
                                      "value": "title"
                                    },
                                    {
                                      "label": "$t:sirsoft-page.admin.page.search_fields.slug",
                                      "value": "slug"
                                    }
                                  ]
                                },
                                "actions": [
                                  {
                                    "type": "change",
                                    "handler": "setState",
                                    "params": {
                                      "searchField": "{{$event.target.value}}"
                                    }
                                  }
                                ]
                              },
                              {
                                "id": "mobile_search_input",
                                "type": "basic",
                                "name": "Input",
                                "props": {
                                  "type": "text",
                                  "placeholder": "$t:sirsoft-page.admin.page.search_placeholder",
                                  "value": "{{_local.searchQuery || ''}}",
                                  "className": "flex-1 min-w-0"
                                },
                                "actions": [
                                  {
                                    "type": "change",
                                    "handler": "setState",
                                    "params": {
                                      "searchQuery": "{{$event.target.value}}"
                                    }
                                  },
                                  {
                                    "type": "keypress",
                                    "key": "Enter",
                                    "handler": "navigate",
                                    "params": {
                                      "path": "/admin/pages",
                                      "mergeQuery": true,
                                      "query": {
                                        "filters[0][field]": "{{_local.searchField || 'all'}}",
                                        "filters[0][value]": "{{$event.target.value}}",
                                        "filters[0][operator]": "like",
                                        "page": 1
                                      },
                                      "transition_overlay_target": "pages_data_grid__body"
                                    }
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "id": "mobile_search_button",
                            "type": "basic",
                            "name": "Button",
                            "props": {
                              "className": "btn btn-primary w-full"
                            },
                            "actions": [
                              {
                                "type": "click",
                                "handler": "navigate",
                                "params": {
                                  "path": "/admin/pages",
                                  "mergeQuery": true,
                                  "query": {
                                    "filters[0][field]": "{{_local.searchField || 'all'}}",
                                    "filters[0][value]": "{{_local.searchQuery || ''}}",
                                    "filters[0][operator]": "like",
                                    "page": 1
                                  },
                                  "transition_overlay_target": "pages_data_grid__body"
                                }
                              }
                            ],
                            "children": [
                              {
                                "type": "basic",
                                "name": "Span",
                                "text": "$t:sirsoft-page.admin.page.search"
                              }
                            ]
                          }
                        ],
                        "props": {
                          "className": "row-stack"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          },
          {
            "id": "list_toolbar",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "flex-between mb-4"
            },
            "children": [
              {
                "id": "total_count",
                "type": "basic",
                "name": "Span",
                "props": {
                  "className": "text-secondary text-sm"
                },
                "text": "$t:sirsoft-page.admin.page.total_count|count={{pages?.data?.meta?.total ?? 0}}"
              },
              {
                "id": "list_options",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex-center gap-3"
                },
                "children": [
                  {
                    "id": "published_filter_select",
                    "type": "composite",
                    "name": "Select",
                    "props": {
                      "value": "{{query.published ?? ''}}",
                      "className": "w-32 px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                      "options": [
                        {
                          "label": "$t:sirsoft-page.admin.page.published_filter.all",
                          "value": ""
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.published_filter.published",
                          "value": "1"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.published_filter.unpublished",
                          "value": "0"
                        }
                      ]
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/pages",
                          "mergeQuery": true,
                          "query": {
                            "published": "{{$event.target.value}}",
                            "page": 1
                          },
                          "transition_overlay_target": "pages_data_grid__body"
                        }
                      }
                    ]
                  },
                  {
                    "id": "sort_select",
                    "type": "composite",
                    "name": "Select",
                    "props": {
                      "value": "{{query.sort_by ? (query.sort_by + '_' + (query.sort_order || 'desc')) : 'created_at_desc'}}",
                      "className": "w-32 px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                      "options": [
                        {
                          "label": "$t:sirsoft-page.admin.page.sort.created_at_desc",
                          "value": "created_at_desc"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.sort.created_at_asc",
                          "value": "created_at_asc"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.sort.published_at_desc",
                          "value": "published_at_desc"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.sort.published_at_asc",
                          "value": "published_at_asc"
                        }
                      ]
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/pages",
                          "mergeQuery": true,
                          "query": {
                            "sort_by": "{{$event.target.value.split('_').slice(0, -1).join('_')}}",
                            "sort_order": "{{$event.target.value.split('_').pop()}}",
                            "page": 1
                          },
                          "transition_overlay_target": "pages_data_grid__body"
                        }
                      }
                    ]
                  },
                  {
                    "id": "per_page_select",
                    "type": "composite",
                    "name": "Select",
                    "props": {
                      "value": "{{query.per_page || '20'}}",
                      "className": "w-20 px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg text-sm",
                      "options": [
                        {
                          "label": "$t:sirsoft-page.admin.page.per_page|count=10",
                          "value": "10"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.per_page|count=20",
                          "value": "20"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.per_page|count=50",
                          "value": "50"
                        },
                        {
                          "label": "$t:sirsoft-page.admin.page.per_page|count=100",
                          "value": "100"
                        }
                      ]
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "navigate",
                        "params": {
                          "path": "/admin/pages",
                          "mergeQuery": true,
                          "query": {
                            "per_page": "{{$event.target.value}}",
                            "page": 1
                          },
                          "transition_overlay_target": "pages_data_grid__body"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "bulk_actions_area",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "bulk-actions-bar"
            },
            "children": [
              {
                "id": "selected_count",
                "type": "basic",
                "name": "Span",
                "props": {
                  "className": "text-body font-medium"
                },
                "text": "$t:sirsoft-page.admin.page.selected_count|count={{(_global.selectedIds_admin_pages || []).length}}"
              },
              {
                "id": "bulk_status_label",
                "type": "basic",
                "name": "Span",
                "props": {
                  "className": "text-label-subtle"
                },
                "text": "$t:sirsoft-page.admin.page.bulk_status_change"
              },
              {
                "id": "bulk_buttons",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex gap-2"
                },
                "children": [
                  {
                    "id": "bulk_publish",
                    "type": "basic",
                    "name": "Button",
                    "props": {
                      "type": "button",
                      "className": "btn btn-sm btn-success",
                      "disabled": "{{!_global.selectedIds_admin_pages || _global.selectedIds_admin_pages.length === 0 || pages?.data?.abilities?.can_update !== true}}"
                    },
                    "actions": [
                      {
                        "type": "click",
                        "handler": "openModal",
                        "target": "bulk_publish_modal"
                      }
                    ],
                    "children": [
                      {
                        "type": "basic",
                        "name": "Span",
                        "text": "$t:sirsoft-page.admin.page.bulk_publish"
                      }
                    ]
                  },
                  {
                    "id": "bulk_unpublish",
                    "type": "basic",
                    "name": "Button",
                    "props": {
                      "type": "button",
                      "className": "btn btn-sm btn-neutral",
                      "disabled": "{{!_global.selectedIds_admin_pages || _global.selectedIds_admin_pages.length === 0 || pages?.data?.abilities?.can_update !== true}}"
                    },
                    "actions": [
                      {
                        "type": "click",
                        "handler": "openModal",
                        "target": "bulk_unpublish_modal"
                      }
                    ],
                    "children": [
                      {
                        "type": "basic",
                        "name": "Span",
                        "text": "$t:sirsoft-page.admin.page.bulk_unpublish"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "pages_data_grid",
            "type": "composite",
            "name": "DataGrid",
            "blur_until_loaded": true,
            "props": {
              "columns": [
                {
                  "field": "title",
                  "header": "$t:sirsoft-page.admin.page.columns.title",
                  "sortable": false,
                  "required": true,
                  "cellChildren": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "stack-flush gap-0.5"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "font-medium text-gray-900 dark:text-white"
                          },
                          "text": "{{row.title ?? ''}}"
                        },
                        {
                          "type": "basic",
                          "name": "A",
                          "props": {
                            "href": "/page/{{row.slug ?? ''}}",
                            "target": "_blank",
                            "className": "text-xs text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:underline"
                          },
                          "text": "/page/{{row.slug ?? ''}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "field": "slug",
                  "header": "$t:sirsoft-page.admin.page.columns.slug",
                  "sortable": false,
                  "cellChildren": [
                    {
                      "type": "basic",
                      "name": "A",
                      "props": {
                        "href": "/page/{{row.slug ?? ''}}",
                        "target": "_blank",
                        "className": "text-sm text-gray-600 dark:text-gray-400 font-mono hover:text-blue-600 dark:hover:text-blue-400 hover:underline"
                      },
                      "text": "{{row.slug ?? ''}}"
                    }
                  ]
                },
                {
                  "field": "published",
                  "header": "$t:sirsoft-page.admin.page.columns.published",
                  "sortable": false,
                  "cellChildren": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "{{row.published ? 'badge badge-green' : 'badge badge-gray'}}"
                      },
                      "text": "{{row.published ? '$t:sirsoft-page.admin.page.published_status.published' : '$t:sirsoft-page.admin.page.published_status.unpublished'}}"
                    }
                  ]
                },
                {
                  "field": "current_version",
                  "header": "$t:sirsoft-page.admin.page.columns.current_version",
                  "sortable": false,
                  "cellChildren": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm text-gray-600 dark:text-gray-400"
                      },
                      "text": "v{{row.current_version}}"
                    }
                  ]
                },
                {
                  "field": "created_at",
                  "header": "$t:sirsoft-page.admin.page.columns.created_at",
                  "sortable": true
                },
                {
                  "field": "published_at",
                  "header": "$t:sirsoft-page.admin.page.columns.published_at",
                  "sortable": true
                }
              ],
              "data": "{{pages?.data?.data}}",
              "sortable": true,
              "sortField": "{{query.sort_by}}",
              "sortDirection": "{{query.sort_order || 'desc'}}",
              "pagination": true,
              "alwaysShowPagination": true,
              "pageSize": 20,
              "serverSidePagination": true,
              "serverCurrentPage": "{{pages?.data?.meta?.current_page ?? 1}}",
              "serverTotalPages": "{{pages?.data?.meta?.last_page ?? 1}}",
              "selectable": true,
              "selectedCountText": "",
              "selectedIds": "{{_global.selectedIds_admin_pages || []}}",
              "idField": "id",
              "responsiveBreakpoint": 768,
              "rowActions": [
                {
                  "id": "view",
                  "label": "$t:sirsoft-page.admin.page.actions.view",
                  "iconName": "eye"
                },
                {
                  "id": "edit",
                  "label": "$t:sirsoft-page.admin.page.actions.edit",
                  "iconName": "pencil",
                  "disabledField": "abilities.can_update"
                },
                {
                  "id": "delete",
                  "label": "$t:sirsoft-page.admin.page.actions.delete",
                  "iconName": "trash",
                  "variant": "danger",
                  "disabledField": "abilities.can_delete"
                }
              ],
              "actionsColumnHeader": "$t:common.actions"
            },
            "actions": [
              {
                "event": "onSelectionChange",
                "type": "change",
                "handler": "setState",
                "params": {
                  "target": "global",
                  "selectedIds_admin_pages": "{{$args[0]}}"
                }
              },
              {
                "event": "onSortChange",
                "type": "change",
                "handler": "navigate",
                "params": {
                  "path": "/admin/pages",
                  "mergeQuery": true,
                  "query": {
                    "sort_by": "{{$args[0]}}",
                    "sort_order": "{{$args[1]}}"
                  }
                }
              },
              {
                "event": "onPageChange",
                "type": "change",
                "handler": "navigate",
                "params": {
                  "path": "/admin/pages",
                  "mergeQuery": true,
                  "query": {
                    "page": "{{$args[0]}}"
                  },
                  "transition_overlay_target": "pages_data_grid__body"
                }
              },
              {
                "event": "onRowAction",
                "type": "action",
                "handler": "switch",
                "cases": {
                  "view": {
                    "handler": "navigate",
                    "params": {
                      "path": "/admin/pages/{{$args[1].id}}"
                    }
                  },
                  "edit": {
                    "handler": "navigate",
                    "params": {
                      "path": "/admin/pages/{{$args[1].id}}/edit"
                    }
                  },
                  "delete": {
                    "handler": "sequence",
                    "actions": [
                      {
                        "handler": "setState",
                        "params": {
                          "target": "global",
                          "deletePageId": "{{$args[1].id}}"
                        }
                      },
                      {
                        "handler": "openModal",
                        "target": "delete_confirm_modal"
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      }
