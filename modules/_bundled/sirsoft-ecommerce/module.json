    },
    "g7_version": ">=7.0.0",
    "dependencies": {
        "modules": {},
        "plugins": {}
    },
    "github_url": "https://github.com/gnuboard/g7-module-sirsoft-ecommerce",
    "github_changelog_url": "https://github.com/gnuboard/g7-module-sirsoft-ecommerce/blob/main/CHANGELOG.md",
    "assets": {
