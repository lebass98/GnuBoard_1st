{
  "version": "1.0.0",
  "layout_name": "admin_ecommerce_settings",
  "permissions": [
    "sirsoft-ecommerce.settings.read"
  ],
  "extends": "_admin_base",
  "meta": {
    "title": "$t:sirsoft-ecommerce.admin.settings.title",
    "description": "$t:sirsoft-ecommerce.admin.settings.description"
  },
  "computed": {
    "isReadOnly": "{{settings?.data?.abilities?.can_update !== true}}",
    "isNotificationReadOnly": "{{ecommerceNotificationDefinitions?.data?.abilities?.can_update !== true}}"
  },
  "state": {
    "notificationDefinitionCurrentPage": 1,
    "notificationDefinitionTotalPages": 1,
    "notificationDefinitionTotalItems": 0,
    "isClearingCache": false
  },
  "transition_overlay": {
    "wait_for": [
      "settings",
      "seoStats",
      "carriers",
      "ecommerceNotificationDefinitions",
      "availableChannels"
    ],
    "target": "ecommerce_settings_tab_content",
    "fallback_target": "right_content_area"
  },
  "data_sources": [
    {
      "id": "settings",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.settings",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/admin/settings",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "initLocal": "form",
      "refetchOnMount": true,
      "errorHandling": {
        "403": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    },
    {
      "id": "seoStats",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.seoStats",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/admin/settings/seo-cache-info",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true
    },
    {
      "id": "carriers",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.carriers",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/admin/shipping-carriers",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "errorHandling": {
        "default": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    },
    {
      "id": "ecommerceNotificationDefinitions",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.ecommerceNotificationDefinitions",
      "type": "api",
      "endpoint": "/api/admin/notification-definitions?extension_type=module&extension_identifier=sirsoft-ecommerce",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "params": {
        "page": "{{query.page || 1}}",
        "per_page": "{{query.per_page || 20}}",
        "search": "{{query.search}}",
        "search_type": "{{query.search_type}}"
      },
      "initLocal": {
        "_merge": "deep",
        "notificationDefinitionCurrentPage": "pagination.current_page",
        "notificationDefinitionTotalPages": "pagination.last_page",
        "notificationDefinitionTotalItems": "pagination.total"
      },
      "fallback": {
        "data": {
          "data": [],
          "pagination": []
        }
      },
      "errorHandling": {
        "default": {
          "handler": "showErrorPage",
          "params": {
            "target": "content"
          }
        }
      }
    },
    {
      "id": "availableChannels",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.availableChannels",
      "type": "api",
      "endpoint": "/api/admin/notification-channels",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "fallback": {
        "data": {
          "channels": []
        }
      }
    },
    {
      "id": "ecommerceIdentityPolicies",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.ecommerceIdentityPolicies",
      "type": "api",
      "endpoint": "/api/admin/identity/policies",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "params": {
        "source_identifier": "sirsoft-ecommerce",
        "source_type": "{{query.source_type ?? ''}}",
        "scope": "{{query.scope ?? ''}}",
        "purpose": "{{query.purpose ?? ''}}",
        "search": "{{query.search ?? ''}}",
        "page": "{{query.page || 1}}",
        "per_page": "{{query.per_page || 10}}"
      },
      "fallback": {
        "data": {
          "data": [],
          "meta": {}
        }
      }
    },
    {
      "id": "ecommerceIdentityPurposes",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.ecommerceIdentityPurposes",
      "type": "api",
      "endpoint": "/api/identity/purposes",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "fallback": {
        "data": []
      }
    },
    {
      "id": "identityProviders",
      "label_key": "$t:sirsoft-ecommerce.editor.data_source.identityProviders",
      "type": "api",
      "endpoint": "/api/admin/identity/providers",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "fallback": {
        "data": []
      }
    }
  ],
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "_local",
        "notificationDefinitionCurrentPage": "{{+(query.page || 1)}}"
      }
    }
  ],
  "initLocal": {
    "activeNotificationChannel": null,
    "editingDefinition": null,
    "editingTemplate": null,
    "editLang": "ko",
    "previewData": null,
    "notificationDefinitionFilter": {
      "search": "",
      "searchType": "all"
    },
    "expandedNotificationDefinitionIds": []
  },
  "defines": {
    "currencyToFlag": {
      "KRW": "kr",
      "USD": "us",
      "JPY": "jp",
      "CNY": "cn",
      "EUR": "eu",
      "GBP": "gb",
      "AUD": "au",
      "CAD": "ca",
      "CHF": "ch",
      "HKD": "hk",
      "SGD": "sg",
      "THB": "th",
      "VND": "vn",
      "TWD": "tw",
      "INR": "in",
      "RUB": "ru",
      "BRL": "br",
      "MXN": "mx",
      "ZAR": "za",
      "NZD": "nz"
    }
  },
  "slots": {
    "content": [
      {
        "id": "settings_content",
        "type": "basic",
        "name": "Div",
        "dataKey": "form",
        "trackChanges": true,
        "props": {
          "className": "admin-page-content-responsive"
        },
        "children": [
          {
            "id": "page_header",
            "type": "composite",
            "name": "PageHeader",
            "props": {
              "title": "$t:sirsoft-ecommerce.admin.settings.title",
              "description": "$t:sirsoft-ecommerce.admin.settings.description"
            }
          },
          {
            "id": "read_only_banner",
            "type": "basic",
            "name": "Div",
            "if": "{{_computed.isReadOnly}}",
            "props": {
              "className": "alert-warning"
            },
            "children": [
              {
                "type": "basic",
                "name": "Icon",
                "props": {
                  "name": "fas fa-lock",
                  "className": "text-yellow-600 dark:text-yellow-400"
                }
              },
              {
                "type": "basic",
                "name": "Span",
                "props": {
                  "className": "text-warning-soft"
                },
                "text": "$t:sirsoft-ecommerce.common.read_only_notice"
              }
            ]
          },
          {
            "comment": "className 은 sticky-tab-nav-responsive 를 쓴다 — 이 화면의 콘텐츠 래퍼가 admin-page-content-responsive(p-4 sm:p-6 lg:p-8) 라 뷰포트마다 좌우 패딩이 다르기 때문. 고정 24px 를 가정하는 sticky-tab-nav(-mx-6 px-6)를 쓰면 폰(p-4=16px)에서 좌우로 8px 씩 과다 bleed 되어 콘텐츠 영역을 넘친다.",
            "id": "tab_navigation",
            "type": "composite",
            "name": "TabNavigation",
            "props": {
              "tabs": [
                {
                  "id": "basic_info",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.basic_info"
                },
                {
                  "id": "language_currency",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.language_currency"
                },
                {
                  "id": "seo",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.seo"
                },
                {
                  "id": "order_settings",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.order_settings"
                },
                {
                  "id": "claim",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.claim"
                },
                {
                  "id": "shipping",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.shipping"
                },
                {
                  "id": "review_settings",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.review_settings"
                },
                {
                  "id": "notification_definitions",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.notification_definitions"
                },
                {
                  "id": "identity_policies",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.identity_policies"
                },
                {
                  "id": "mileage",
                  "label": "$t:sirsoft-ecommerce.admin.settings.tabs.mileage"
                }
              ],
              "activeTabId": "{{_global.activeEcommerceSettingsTab || query.tab || 'basic_info'}}",
              "variant": "default",
              "className": "sticky-tab-nav-responsive"
            },
            "actions": [
              {
                "event": "onTabChange",
                "type": "change",
                "handler": "sequence",
                "params": {
                  "actions": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "errors": null
                      }
                    },
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "activeEcommerceSettingsTab": "{{$args[0]}}"
                      }
                    },
                    {
                      "handler": "navigate",
                      "params": {
                        "path": "/admin/ecommerce/settings",
                        "query": {
                          "tab": "{{$args[0]}}"
                        },
                        "replace": true
                      }
                    }
                  ]
                }
              }
            ]
          },
          {
            "id": "ecommerce_settings_tab_content",
            "type": "basic",
            "name": "Div",
            "children": [
              {
                "id": "validation_error",
                "type": "basic",
                "name": "Div",
                "if": "{{_local.errors}}",
                "props": {
                  "className": "alert-danger"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "flex gap-3"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Icon",
                        "props": {
                          "name": "triangle-exclamation",
                          "className": "text-xl text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5"
                        }
                      },
                      {
                        "type": "basic",
                        "name": "Div",
                        "children": [
                          {
                            "type": "basic",
                            "name": "H3",
                            "props": {
                              "className": "text-error-strong"
                            },
                            "text": "$t:sirsoft-ecommerce.admin.settings.validation_error"
                          },
                          {
                            "type": "basic",
                            "name": "P",
                            "if": "{{typeof _local.errors === 'string'}}",
                            "props": {
                              "className": "text-error-soft mt-2"
                            },
                            "text": "{{_local.errors}}"
                          },
                          {
                            "type": "basic",
                            "name": "Ul",
                            "if": "{{typeof _local.errors === 'object' && Object.keys(_local.errors).length > 0}}",
                            "props": {
                              "className": "mt-2 list-disc list-inside space-y-1"
                            },
                            "iteration": {
                              "source": "Object.entries(_local.errors ?? {}).flatMap(([field, messages]) => Array.isArray(messages) ? messages : [messages])",
                              "item_var": "message"
                            },
                            "children": [
                              {
                                "type": "basic",
                                "name": "Li",
                                "props": {
                                  "className": "text-error-soft"
                                },
                                "text": "{{message}}"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_basic_info.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_language_currency.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_seo.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_order_settings.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_claim.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_shipping.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_review_settings.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_notification_definitions.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_identity_policies.json"
              },
              {
                "partial": "partials/admin_ecommerce_settings/_tab_mileage.json"
              }
            ],
            "props": {
              "className": "tab-content"
            }
          },
          {
            "id": "footer_buttons",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "sticky-footer-buttons"
            },
            "children": [
              {
                "id": "cancel_button",
                "type": "basic",
                "name": "Button",
                "props": {
                  "className": "btn btn-secondary"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "navigate",
                    "params": {
                      "path": "/admin"
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:common.cancel"
                  }
                ]
              },
              {
                "id": "save_button",
                "type": "basic",
                "name": "Button",
                "props": {
                  "disabled": "{{_computed.isReadOnly || !_local.hasChanges || _local.isSaving}}",
                  "className": "btn btn-primary flex-center gap-1.5"
                },
                "actions": [
                  {
                    "type": "click",
                    "handler": "sequence",
                    "params": {
                      "actions": [
                        {
                          "handler": "toast",
                          "if": "{{_local.isAddingMileageCurrency === true || _local.isAddingCurrency === true}}",
                          "params": {
                            "type": "error",
                            "message": "$t:sirsoft-ecommerce.admin.settings.save_pending_currency"
                          }
                        },
                        {
                          "handler": "setState",
                          "if": "{{!(_local.isAddingMileageCurrency === true || _local.isAddingCurrency === true)}}",
                          "params": {
                            "target": "local",
                            "isSaving": true,
                            "errors": null
                          }
                        },
                        {
                          "handler": "apiCall",
                          "if": "{{!(_local.isAddingMileageCurrency === true || _local.isAddingCurrency === true)}}",
                          "auth_required": true,
                          "target": "/api/modules/sirsoft-ecommerce/admin/settings",
                          "params": {
                            "method": "PUT",
                            "body": "{{(function() { const tab = _global.activeEcommerceSettingsTab || query.tab || 'basic_info'; const form = _local.form ?? {}; if (tab === 'notification_definitions') { return { _tab: 'notifications', notifications: { channels: form.notifications?.channels || [] } }; } if (tab === 'mileage') { return { _tab: 'mileage', mileage: form.mileage ?? {} }; } return { _tab: tab, [tab]: form[tab] ?? {}, inquiry: form.inquiry ?? {} }; })()}}"
                          },
                          "onSuccess": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSaving": false,
                                "hasChanges": false,
                                "isAddingCurrency": false,
                                "form.newCurrency": null,
                                "isAddingMileageCurrency": false,
                                "form.newMileageCurrency": null
                              }
                            },
                            {
                              "handler": "refetchDataSource",
                              "params": {
                                "dataSourceId": "settings",
                                "sync": true
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "success",
                                "message": "$t:sirsoft-ecommerce.admin.settings.save_success"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSaving": false,
                                "errors": "{{error.errors}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "error",
                                "message": "$t:sirsoft-ecommerce.admin.settings.save_error"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  }
                ],
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "if": "{{_local.isSaving}}",
                    "props": {
                      "name": "spinner",
                      "className": "spinner-sm"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "Span",
                    "if": "{{!_local.isSaving}}",
                    "text": "$t:common.save"
                  },
                  {
                    "type": "basic",
                    "name": "Span",
                    "if": "{{_local.isSaving}}",
                    "text": "$t:common.saving"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "modals": [
    {
      "partial": "partials/admin_ecommerce_settings/_bank_management_modal.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_disable_international_shipping_modal.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_notification_template_edit.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_notification_template_preview.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_notification_definition_reset.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_clear_seo_cache.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_identity_policy_form.json"
    },
    {
      "partial": "partials/admin_ecommerce_settings/_modal_identity_policy_delete.json"
    }
  ]
}
