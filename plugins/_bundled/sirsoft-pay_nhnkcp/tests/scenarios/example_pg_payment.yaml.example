# 시나리오 매니페스트 예시 (실제 적용 아님 — .yaml.example 확장자)
# 실제 매니페스트로 채택할 때 .yaml 로 이름 변경 + test_files 의 실재 경로 매핑
#
# 참조: docs/testing-guide.md "기능 단위 시나리오 매트릭스"

feature: order_payment_pg_nhnkcp
description: NHN KCP Standard Pay 를 통한 주문 결제 흐름 (회원/비회원, 결제 수단, 가상계좌 등 도메인 변수 cross product)

test_files:
  - plugins/_bundled/sirsoft-pay_nhnkcp/tests/Feature/Payment/KcpAuthCallbackTest.php
  - plugins/_bundled/sirsoft-pay_nhnkcp/tests/Feature/Payment/VbankNotifyTest.php
  - plugins/_bundled/sirsoft-pay_nhnkcp/tests/Feature/Payment/CancelTest.php

coverage_strategy: pairwise

# 입력 axis — 결제 흐름에 영향을 주는 도메인 변수
axes:
  user_type: [member, guest]
  payment_method: [card, bank_transfer, virtual_account, mobile]
  is_test_mode: [true, false]
  os_platform: [windows, linux]   # KCP CLI 바이너리가 OS 별로 다름
  product_options: [single, multi_option, bundle]
  shipping_region: [domestic, jeju, remote_island]
  shipping_policy: [free, fixed, range_based, conditional_free]
  coupon_applied: [none, product, category, all]
  rounding_unit: [1, 10, 100]

# 의미 없는 조합 컷 — 사유 명시 필수
exclusions:
  - { payment_method: virtual_account, user_type: guest, reason: "비회원 가상계좌는 환불 계좌 등록 불가" }

# 후속 효과 체인 — 결제 후 모든 부수효과
effects:
  - auth_callback_received
  - cli_approve_called             # KCP CLI 서버 승인
  - res_cd_zero_check
  - payment_completed              # card / mobile / bank_transfer
  - vbank_issued                   # virtual_account 1단계
  - vbank_notification_received    # virtual_account 2단계
  - vbank_deposit_completed        # res_cd 0000 입금완료
  - notification_sent_to_user
  - notification_amount_matches_total
  - vat_calculated
  - tax_free_amount_split
  - coupon_marked_used
  - inventory_decremented
  - order_status_transitioned_to_paid

# 보조 흐름 — 취소/환불/통보 등
sub_flows:
  - id: partial_cancel_card
    description: 카드 결제 부분 취소 (mod_type=RN07, rem_mny 계산)
    effects:
      - before_cancel_hook_invoked     # plugin action hook
      - cli_cancel_called
      - after_cancel_hook_invoked
      - shipping_policy_recalculated
      - discount_recalculated
      - mileage_partial_refunded
      - vat_recalculated

  - id: full_cancel_card
    description: 카드 결제 전액 취소 (mod_type=STSC)
    effects:
      - before_cancel_hook_invoked
      - cli_cancel_called
      - after_cancel_hook_invoked
      - mileage_fully_refunded
      - coupon_unused
      - inventory_restored
      - order_status_transitioned_to_cancelled

  - id: user_cancel_at_pg_dialog
    description: 사용자가 결제창에서 취소 (m_Completepayment res_cd != '0000')
    effects:
      - kcp_cancelled_error_thrown
      - silent_cleanup_no_toast
      - no_payment_record_created

  - id: vbank_repeat_notification
    description: 동일 tno 입금 통보 재발송 시 중복 처리 방지
    effects:
      - row_lock_acquired
      - already_paid_short_circuited
      - ok_response_returned

notes: |
  이 매니페스트는 예시이며 실제 채택 시 다음을 갱신하세요:
   1. test_files 경로
   2. axes 값 목록 (특히 KCP CLI OS 분기는 Windows/Linux 모두 검증 필요)
   3. effects 명명 (테스트 docblock @effects 와 1:1 매칭)
   4. before_cancel / after_cancel 훅은 sirsoft-pay_nhnkcp.payment.before_cancel / after_cancel
  pairwise 전략 케이스 수: 약 30 (full 일 경우 2*4*2*2*3*3*4*4*3 = 6,912)
