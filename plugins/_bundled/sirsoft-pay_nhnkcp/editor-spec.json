{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "레이아웃 편집기 스펙 — NHN KCP 결제 플러그인 도메인 sampleData. plugin_settings 레이아웃의 data_source 중 플러그인 고유 ID(vbank_info / health) 의 응답 shape 를 실제 바인딩(vbank_info.data.{notify_url,guide_steps,...} / health.data.{data.overall,checks.*}) 역추론해 작성. 공통 ID 'settings' 는 admin 템플릿 스펙 sampleData 가 커버(전역 고유 ID 병합 specMerge 템플릿 우선)하므로 본 스펙에 미포함.",
  "pluginId": "sirsoft-pay_nhnkcp",
  "version": "1.0.0",
  "description": "NHN KCP 결제 플러그인 레이아웃 편집기 샘플 데이터 (가상계좌 입금통보 URL / 연동 상태 점검).",
  "sampleData": {
    "byDataSourceId": {
      "vbank_info": {
        "data": {
          "title": "가상계좌 입금통보 URL",
          "description": "아래 URL 을 PG 관리자에 등록하면 입금 완료 시 자동으로 주문이 처리됩니다.",
          "notify_url": "https://example.com/api/plugins/sirsoft-pay_nhnkcp/vbank/notify",
          "copyable": true,
          "guide_url": "https://example.com/docs/vbank",
          "guide_steps": [
            "PG 관리자 페이지에 로그인합니다.",
            "가상계좌 입금통보 URL 설정 메뉴로 이동합니다.",
            "위 URL 을 붙여넣고 저장합니다."
          ]
        }
      },
      "health": {
        "data": {
          "summary": {
            "pc_payment_ready": true,
            "mobile_payment_ready": false,
            "mobile_vbank_only_ready": false,
            "error_count": 1,
            "warning_count": 0,
            "fixed_count": 0
          },
          "checks": [
            {
              "id": "exec_function",
              "category": "pc",
              "label": "PHP exec() 함수",
              "status": "ok",
              "detail": "CLI 호출 가능"
            },
            {
              "id": "bin_directory",
              "category": "pc",
              "label": "CLI 바이너리 디렉토리",
              "status": "ok",
              "detail": "디렉토리 존재"
            },
            {
              "id": "cli_pp_cli_exe",
              "category": "pc",
              "label": "CLI 바이너리 (Windows) — pp_cli_exe.exe",
              "status": "ok",
              "detail": "Windows 바이너리 — 실행 권한 검사 생략"
            },
            {
              "id": "pub_key",
              "category": "pc",
              "label": "KCP 공개키 (pub.key)",
              "status": "ok",
              "detail": "파일 존재"
            },
            {
              "id": "soap_extension",
              "category": "mobile",
              "label": "PHP SOAP 확장",
              "status": "error",
              "detail": "모바일 결제 (SmartPhone Pay) 가 동작하지 않습니다.",
              "remediation": "PHP SOAP 확장을 설치하고 PHP-FPM 을 재시작하세요:\nUbuntu/Debian: sudo apt install php8.x-soap && sudo systemctl restart php8.x-fpm\nRHEL/CentOS:   sudo yum install php-soap && sudo systemctl restart php-fpm\n확인: php -m | grep soap"
            },
            {
              "id": "wsdl_file",
              "category": "mobile",
              "label": "WSDL 파일",
              "status": "ok",
              "detail": "테스트/라이브 WSDL 모두 존재"
            }
          ]
        }
      }
    }
  },
  "states": {
    "comment": "플러그인 설정 변종.",
    "groups": [
      {
        "comment": "결제/인증 플러그인 설정. _local.form.is_test_mode 로 운영모드 경고(live_mode_warning)를 if 분기한다.",
        "scope": {
          "kind": "route",
          "match": "*/admin/plugins/sirsoft-pay_nhnkcp/settings"
        },
        "items": [
          {
            "id": "test_mode_on",
            "label": "$t:editor.state.test_mode_on",
            "default": true,
            "initialState": {
              "local": {
                "form": {
                  "is_test_mode": true
                }
              }
            }
          },
          {
            "id": "test_mode_off",
            "label": "$t:editor.state.test_mode_off",
            "initialState": {
              "local": {
                "form": {
                  "is_test_mode": false
                }
              }
            }
          }
        ]
      }
    ]
  }
}
