{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$comment": "레이아웃 편집기 스펙 — 나이스페이먼츠 결제 플러그인 도메인 sampleData. plugin_settings 의 플러그인 고유 ID(vbank_info) 응답 shape 를 실제 바인딩(vbank_info.data.{notify_url,guide_steps,...}) 역추론. 공통 ID 'settings' 는 admin 템플릿 sampleData 가 커버(전역 고유 ID 병합)하므로 미포함.",
    "pluginId": "sirsoft-pay_nicepayments",
    "version": "1.0.0",
    "description": "나이스페이먼츠 결제 플러그인 레이아웃 편집기 샘플 데이터 (가상계좌 입금통보 URL).",
    "sampleData": {
        "byDataSourceId": {
            "vbank_info": {
                "data": {
                    "title": "가상계좌 입금통보 URL",
                    "description": "아래 URL 을 PG 관리자에 등록하면 입금 완료 시 자동으로 주문이 처리됩니다.",
                    "notify_url": "https://example.com/api/plugins/sirsoft-pay_nicepayments/vbank/notify",
                    "copyable": true,
                    "guide_url": "https://example.com/docs/vbank",
                    "guide_steps": [
                        "PG 관리자 페이지에 로그인합니다.",
                        "가상계좌 입금통보 URL 설정 메뉴로 이동합니다.",
                        "위 URL 을 붙여넣고 저장합니다."
                    ]
                }
            }
        }
    },
    "states": {
        "comment": "플러그인 설정 변종.",
        "groups": [
            {
                "comment": "결제/인증 플러그인 설정. _local.form.is_test_mode 로 운영모드 경고(live_mode_warning)를 if 분기한다.",
                "scope": {
                    "kind": "route",
                    "match": "*/admin/plugins/sirsoft-pay_nicepayments/settings"
                },
                "items": [
                    {
                        "id": "test_mode_on",
                        "label": "$t:editor.state.test_mode_on",
                        "default": true,
                        "initialState": {
                            "local": {
                                "form": {
                                    "is_test_mode": true
                                }
                            }
                        }
                    },
                    {
                        "id": "test_mode_off",
                        "label": "$t:editor.state.test_mode_off",
                        "initialState": {
                            "local": {
                                "form": {
                                    "is_test_mode": false
                                }
                            }
                        }
                    }
                ]
            }
        ]
    }
}
