# 시나리오 매니페스트 예시 (실제 적용 아님 — .yaml.example 확장자)
# 실제 매니페스트로 채택할 때 .yaml 로 이름 변경 + test_files 의 실재 경로 매핑
#
# 참조: docs/testing-guide.md "기능 단위 시나리오 매트릭스"

feature: order_payment_pg_nicepayments
description: 나이스페이먼츠 PG 를 통한 주문 결제 흐름 (회원/비회원, 결제 수단, 가상계좌, 에스크로, 간편결제 등 도메인 변수 cross product)

# 매니페스트를 검증하는 테스트 파일 (실제 작성 시 경로 갱신)
test_files:
  - plugins/_bundled/sirsoft-pay_nicepayments/tests/Feature/Payment/NicePayAuthCallbackTest.php
  - plugins/_bundled/sirsoft-pay_nicepayments/tests/Feature/Payment/VbankNotifyTest.php
  - plugins/_bundled/sirsoft-pay_nicepayments/tests/Feature/Payment/CancelTest.php

# 축이 많아 full cross product 가 폭발하므로 pairwise 전략
coverage_strategy: pairwise

# 입력 axis — 결제 흐름에 영향을 주는 도메인 변수 전수
axes:
  user_type: [member, guest]
  payment_method: [card, bank_transfer, virtual_account, mobile]
  easy_pay: [none, naverpay, kakaopay, samsungpay, applepay, payco, skpay, ssgpay, lpay]
  is_test_mode: [true, false]
  use_escrow: [true, false]
  product_options: [single, multi_option, bundle]
  shipping_region: [domestic, jeju, remote_island]
  shipping_policy: [free, fixed, range_based, conditional_free]
  coupon_applied: [none, product, category, all]
  rounding_unit: [1, 10, 100]

# 의미 없는 조합 컷 — 사유 명시 필수
exclusions:
  - { payment_method: virtual_account, easy_pay: kakaopay, reason: "가상계좌는 간편결제와 동시 적용 불가" }
  - { payment_method: virtual_account, use_escrow: true, easy_pay: naverpay, reason: "에스크로 가상계좌는 간편결제 비대상" }
  - { easy_pay: applepay, payment_method: bank_transfer, reason: "간편결제는 카드 결제 수단으로만 진입" }
  - { easy_pay: applepay, payment_method: virtual_account, reason: "간편결제는 카드 결제 수단으로만 진입" }
  - { easy_pay: applepay, payment_method: mobile, reason: "간편결제는 카드 결제 수단으로만 진입" }
  - { user_type: guest, easy_pay: naverpay, reason: "비회원은 간편결제 미지원" }

# 후속 효과 체인 — 결제 후 모든 부수효과
effects:
  - auth_callback_received
  - signature_verified
  - mid_matched
  - server_authorize_called
  - payment_completed              # card / mobile / easy_pay
  - vbank_issued                   # virtual_account 1단계
  - vbank_notification_received    # virtual_account 2단계
  - vbank_deposit_completed        # ResultCode 4110
  - notification_sent_to_user
  - notification_amount_matches_total
  - vat_calculated
  - tax_free_amount_split
  - coupon_marked_used
  - inventory_decremented
  - order_status_transitioned_to_paid

# 보조 흐름 — 취소/환불/통보 등
sub_flows:
  - id: partial_cancel_card
    description: 카드 결제 부분 취소 (CancelAmt < 원결제 금액)
    effects:
      - before_cancel_hook_invoked     # plugin action hook
      - cancel_api_called
      - after_cancel_hook_invoked
      - shipping_policy_recalculated
      - discount_recalculated
      - mileage_partial_refunded
      - vat_recalculated

  - id: full_cancel_card
    description: 카드 결제 전액 취소
    effects:
      - before_cancel_hook_invoked
      - payment_voided
      - after_cancel_hook_invoked
      - mileage_fully_refunded
      - coupon_unused
      - inventory_restored
      - order_status_transitioned_to_cancelled

  - id: vbank_refund_after_deposit
    description: 입금 완료된 가상계좌 환불 (관리자 경로 — 환불 계좌 정보 필수)
    effects:
      - admin_refund_endpoint_called
      - refund_account_validated
      - cancel_api_called_with_bank_info
      - vat_recalculated
      - order_status_transitioned_to_cancelled

  - id: user_cancel_at_pg_dialog
    description: 사용자가 결제창에서 '취소' 또는 '종료' 선택 (AuthResultCode != '0000')
    effects:
      - redirect_to_checkout_without_error_query
      - no_payment_record_created

  - id: vbank_repeat_notification
    description: 동일 TID 입금 통보 재발송 시 중복 처리 방지
    effects:
      - row_lock_acquired
      - already_paid_short_circuited
      - ok_response_returned

notes: |
  이 매니페스트는 예시이며 실제 채택 시 다음을 갱신하세요:
   1. test_files 경로
   2. axes 값 목록 (특히 easy_pay 는 plugin.json easy_pay_* 설정과 동기)
   3. effects 명명 (테스트 docblock @effects 와 1:1 매칭)
   4. before_cancel / after_cancel 훅은 sirsoft-pay_nicepayments.payment.before_cancel / after_cancel
  pairwise 전략 케이스 수: 약 30~40 (full 일 경우 2*4*9*2*2*3*3*4*4*3 = 41,472)
